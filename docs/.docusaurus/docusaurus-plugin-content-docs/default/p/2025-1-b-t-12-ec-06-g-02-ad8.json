ry/sprint-3"},{"type":"category","label":"Sprint 4","collapsible":true,"collapsed":true,"items":[{"type":"category","label":"Modelo de Pasta","collapsible":true,"collapsed":true,"items":[{"type":"link","label":"Título da Página","href":"/2025-1B-T12-EC06-G02/sprint-4/modelo_de_pasta/modelo_de_arquivo","docId":"sprint-4/modelo_de_pasta/modelo_de_arquivo","unlisted":false}],"href":"/2025-1B-T12-EC06-G02/category/modelo-de-pasta-2"}],"href":"/2025-1B-T12-EC06-G02/category/sprint-4"},{"type":"category","label":"Sprint 5","collapsible":true,"collapsed":true,"items":[{"type":"category","label":"Modelo de Pasta","collapsible":true,"collapsed":true,"items":[{"type":"link","label":"Título da Página","href":"/2025-1B-T12-EC06-G02/sprint-5/modelo_de_pasta/modelo_de_arquivo","docId":"sprint-5/modelo_de_pasta/modelo_de_arquivo","unlisted":false}],"href":"/2025-1B-T12-EC06-G02/category/modelo-de-pasta-3"}],"href":"/2025-1B-T12-EC06-G02/category/sprint-5"}]},"docs":{"intro":{"id":"intro","title":"Introdução","description":"O Projeto","sidebar":"tutorialSidebar"},"sprint-1/analise-de-negocios/analise_de_stakeholder":{"id":"sprint-1/analise-de-negocios/analise_de_stakeholder","title":"Análise dos stakeholders","description":"&emsp; Stakeholder representa o público estratégico, seja um grupo de pessoas ou um indivíduo, que é impactado pelas ações de um empreendimento, de uma empresa, de um negócio ou de um projeto. Nesse sentido, pode-se ser classificado em stakeholders internos e externos à organização, como também primários, com ligação direta ao projeto, e secundários, com ligação indireta ao projeto. Tendo isso em vista, essa análise é fundamental para uma compreensão inicial de todas as pessoas que utilizarão ou serão impactadas pela solução a ser desenvolvida, permitindo, assim, a construção de um escopo coerente com as necessidades desse público. Assim, segue a classificação dos stakeholders do presente projeto:","sidebar":"tutorialSidebar"},"sprint-1/analise-de-negocios/analise_pestel":{"id":"sprint-1/analise-de-negocios/analise_pestel","title":"Análise PESTEL","description":"&emsp; Nesta sprint, diversas metodologias foram empregadas com o objetivo de proporcionar à SOD uma compreensão aprofundada tanto da solução a ser entregue quanto do papel de sua equipe na resolução do problema em questão. Dentre os instrumentos utilizados, destacam-se o Canvas Proposta de Valor, o Business Model Canvas e a Matriz de Risco, os quais auxiliaram na construção de uma visão estratégica do projeto.","sidebar":"tutorialSidebar"},"sprint-1/analise-de-negocios/Business_Model_Canvas":{"id":"sprint-1/analise-de-negocios/Business_Model_Canvas","title":"Business Model Canvas","description":"1. Introdução","sidebar":"tutorialSidebar"},"sprint-1/analise-de-negocios/Canva_proposta_de_Valor":{"id":"sprint-1/analise-de-negocios/Canva_proposta_de_Valor","title":"Canvas Proposta de Valor","description":"Introdução","sidebar":"tutorialSidebar"},"sprint-1/analise-de-negocios/Matriz_de_Risco":{"id":"sprint-1/analise-de-negocios/Matriz_de_Risco","title":"Matriz de Riscos","description":"Introdução","sidebar":"tutorialSidebar"},"sprint-1/especificacoes-tecnicas/Arquitetura_Inicial":{"id":"sprint-1/especificacoes-tecnicas/Arquitetura_Inicial","title":"Arquitetura Inicial","description":"A arquitetura de software representa o alicerce fundamental sobre o qual todo o sistema é construído, definindo sua estrutura, comportamento e propriedades essenciais. Para o sistema óptico de detecção [de fissuras em revestimentos], uma arquitetura bem planejada é crucial pois fornece uma visão clara da organização e integração dos componentes do sistema, facilita a comunicação entre equipes técnicas e stakeholders do projeto, permite a identificação precoce de riscos e pontos de atenção, estabelece as bases para a escalabilidade e manutenibilidade do software, assegura que requisitos não-funcionais como desempenho, segurança e usabilidade sejam adequadamente atendidos, e define os limites e interfaces entre os diferentes módulos, facilitando o desenvolvimento paralelo","sidebar":"tutorialSidebar"},"sprint-1/especificacoes-tecnicas/Requisitos_Funcionais":{"id":"sprint-1/especificacoes-tecnicas/Requisitos_Funcionais","title":"Requisitos Funcionais","description":"Introdução","sidebar":"tutorialSidebar"},"sprint-1/especificacoes-tecnicas/Requisitos_Nao_Funcionais":{"id":"sprint-1/especificacoes-tecnicas/Requisitos_Nao_Funcionais","title":"Requisitos Não Funcionais","description":"Introdução","sidebar":"tutorialSidebar"},"sprint-1/ux-ui/Arquitetura_Informacao":{"id":"sprint-1/ux-ui/Arquitetura_Informacao","title":"Arquitetura da Informação","description":"Contexto","sidebar":"tutorialSidebar"},"sprint-1/ux-ui/Personas":{"id":"sprint-1/ux-ui/Personas","title":"Personas","description":"Conceito","sidebar":"tutorialSidebar"},"sprint-1/ux-ui/User_Stories":{"id":"sprint-1/ux-ui/User_Stories","title":"User Stories","description":"Conceito","sidebar":"tutorialSidebar"},"sprint-2/modelo_de_pasta/modelo_de_arquivo":{"id":"sprint-2/modelo_de_pasta/modelo_de_arquivo","title":"Título da Página","description":"","sidebar":"tutorialSidebar"},"sprint-3/modelo_de_pasta/modelo_de_arquivo":{"id":"sprint-3/modelo_de_pasta/modelo_de_arquivo","title":"Título da Página","description":"","sidebar":"tutorialSidebar"},"sprint-4/modelo_de_pasta/modelo_de_arquivo":{"id":"sprint-4/modelo_de_pasta/modelo_de_arquivo","title":"Título da Página","description":"","sidebar":"tutorialSidebar"},"sprint-5/modelo_de_pasta/modelo_de_arquivo":{"id":"sprint-5/modelo_de_pasta/modelo_de_arquivo","title":"Título da Página","description":"","sidebar":"tutorialSidebar"}}}}